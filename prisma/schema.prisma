generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model history {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  movie_id   Int?
  action     String   @db.VarChar(20)
  old_data   Json?    @db.Json
  new_data   Json?    @db.Json
  created_at DateTime @default(now()) @db.Timestamp(6)
  movies     movies?  @relation(fields: [movie_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model movies {
  id           Int          @id @default(autoincrement())
  user_admin   Int
  title        String       @db.VarChar(200)
  release_year String       @db.VarChar(4)
  type_movie   movie_rating
  created_at   DateTime     @default(now()) @db.Timestamp(6)
  image_url    String?
  rate         Int?
  history      history[]
  users        users        @relation(fields: [user_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model refresh_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String
  device     String?   @db.VarChar(100)
  is_revoked Boolean   @default(false)
  expires_at DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id             Int              @id @default(autoincrement())
  first_name     String           @db.VarChar(60)
  last_name      String           @db.VarChar(60)
  tel            String           @db.VarChar(10)
  email          String           @unique @db.VarChar(255)
  password       String           @db.VarChar(255)
  role           user_role        @default(FLOORSTAFF)
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @default(now()) @db.Timestamp(6)
  history        history[]
  movies         movies[]
  refresh_tokens refresh_tokens[]
}

enum movie_rating {
  G
  PG
  M
  MA
  R
}

enum user_role {
  MANAGER
  TEAMLEADER
  FLOORSTAFF
}
