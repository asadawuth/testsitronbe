{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
